      ;;
    --skip-test | --skip-tests)
      SKIP_TEST=1
      ;;
    --skip-dependencies)
      SKIP_DEPENDENCIES=1
      ;;
    --)
      shift || true
      break
      ;;
    *)
      showHelp
      Log::fatal "invalid argument $1"
